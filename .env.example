# Server
PORT=3000
NODE_ENV=development

# Frontend dev proxy (Vite)
VITE_API_TARGET=http://localhost:5001

# Database provider: mysql or supabase
DB_PROVIDER=mysql
# Auth provider: local or supabase
AUTH_PROVIDER=local
# Set false to skip startup DB check noise (health endpoint still reports DB status)
DB_STARTUP_CHECK=true

# MySQL Database Connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=event_management
DB_CONNECTION_LIMIT=10

# Supabase Postgres (used only when DB_PROVIDER=supabase)
# Example: postgresql://postgres:[YOUR_PASSWORD]@db.wtvjvbbjdipefxkhikks.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.wtvjvbbjdipefxkhikks.supabase.co:5432/postgres
# Set to false only if your network requires disabling SSL verification (not recommended)
SUPABASE_SSL=true

# Supabase API (optional for supabase-js/Auth/admin operations)
SUPABASE_URL=https://wtvjvbbjdipefxkhikks.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
